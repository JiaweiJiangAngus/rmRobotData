[Unit]
Description=RM Robot Data Bilibili live proxy
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=jwj
WorkingDirectory=/home/jwj/Desktop/rmRobotData
ExecStart=/usr/bin/python3 /home/jwj/Desktop/rmRobotData/bili_live_proxy.py
Restart=always
RestartSec=2
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
